# Openclaw Podcast Agent — Environment Variables
# Copy to .env and fill in your values. NEVER commit .env itself.

# ── Agent Identity ──────────────────────────────────────────────
AGENT_NAME=Podcaster
AGENT_DESCRIPTION=Autonomous podcast production agent

# ── User Profile ────────────────────────────────────────────────
USER_DISPLAY_NAME=
USER_LOCATION=
USER_TIMEZONE=Europe/Berlin
USER_ORIGIN_COUNTRY=
USER_INTERESTS=

# ── Paths ───────────────────────────────────────────────────────
PODCAST_DATA_DIR=.
PODCAST_WORKSPACE_DIR=.
PODCAST_CONFIG_FILE=config/podcast.json
LIBRARIAN_AGENT_WORKSPACE=

# ── Inter-Agent Message Queue (IAMQ) ───────────────────────────
IAMQ_HTTP_URL=http://127.0.0.1:18790
IAMQ_AGENT_ID=podcast_agent

# ── LLM (Ollama) ───────────────────────────────────────────────
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2

# ── TTS Engine ──────────────────────────────────────────────────
# Options: mlx-audio, f5-tts-mlx
TTS_ENGINE=mlx-audio
TTS_QUANTIZATION=4

# ── Audio ───────────────────────────────────────────────────────
AUDIO_SAMPLE_RATE=24000
AUDIO_LOUDNESS_LUFS=-16
AUDIO_TRUE_PEAK_DBTP=-1.0
AUDIO_OUTPUT_FORMAT=mp3
AUDIO_MP3_BITRATE=192

# ── Distribution ────────────────────────────────────────────────
DISTRIBUTION_TYPE=static
DISTRIBUTION_OUTPUT_DIR=output/episodes

# ── Docker ──────────────────────────────────────────────────────
CONTAINER_REGISTRY=
